{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ISAAC AI-Ready Scientific Record v1.05",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "isaac_record_version",
    "record_id",
    "record_type",
    "record_domain",
    "source_type",
    "timestamps"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "record_type": {
            "const": "evidence"
          }
        }
      },
      "then": {
        "required": [
          "descriptors"
        ]
      }
    }
  ],
  "properties": {
    "isaac_record_version": {
      "type": "string",
      "const": "1.05"
    },
    "record_id": {
      "type": "string",
      "pattern": "^[0-9A-Z]{26}$",
      "description": "ULID identifier for the record."
    },
    "record_type": {
      "type": "string",
      "enum": [
        "evidence",
        "intent",
        "synthesis"
      ],
      "description": "Fundamental nature of the record."
    },
    "record_domain": {
      "type": "string",
      "enum": [
        "characterization",
        "performance",
        "simulation",
        "theory",
        "derived"
      ],
      "description": "Scientific domain of the record content."
    },
    "source_type": {
      "type": "string",
      "enum": [
        "facility",
        "laboratory",
        "computation",
        "literature",
        "database",
        "industrial"
      ],
      "description": "Origin of the data acquisition."
    },
    "timestamps": {
      "type": "object",
      "required": [
        "created_utc"
      ],
      "properties": {
        "created_utc": {
          "type": "string",
          "format": "date-time"
        },
        "acquired_start_utc": {
          "type": "string",
          "format": "date-time"
        },
        "acquired_end_utc": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "sample": {
      "type": "object",
      "required": [
        "material",
        "sample_form"
      ],
      "properties": {
        "material": {
          "type": "object",
          "required": [
            "name",
            "formula"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "formula": {
              "type": "string"
            },
            "provenance": {
              "type": "string"
            }
          }
        },
        "sample_form": {
          "type": "string"
        },
        "electrode_type": {
          "type": "string",
          "description": "Type of electrode or substrate configuration (e.g., GDE, RDE, RRDE, foil, MEA)."
        },
        "composition": {
          "type": "object"
        },
        "geometry": {
          "type": "object"
        }
      }
    },
    "system": {
      "type": "object",
      "required": [
        "domain",
        "technique"
      ],
      "properties": {
        "domain": {
          "type": "string",
          "enum": [
            "experimental",
            "computational"
          ]
        },
        "technique": {
          "type": "string",
          "enum": [
            "XAS",
            "HERFD-XAS",
            "XES",
            "RIXS",
            "XPS",
            "XRF",
            "XRD",
            "SAXS",
            "WAXS",
            "PDF",
            "neutron_reflectometry",
            "neutron_diffraction",
            "SANS",
            "cyclic_voltammetry",
            "chronoamperometry",
            "chronopotentiometry",
            "EIS",
            "linear_sweep_voltammetry",
            "TEM",
            "SEM",
            "AFM",
            "STM",
            "DFT",
            "ab_initio_MD",
            "classical_MD",
            "kinetic_monte_carlo",
            "microkinetic_modeling",
            "machine_learning_potential",
            "GC",
            "HPLC",
            "ICP_MS",
            "ICP_OES",
            "NMR",
            "mass_spectrometry",
            "FTIR",
            "Raman",
            "UV_Vis"
          ],
          "description": "Primary technique or computational method used to produce this record."
        },
        "facility": {
          "type": "object"
        },
        "instrument": {
          "type": "object"
        },
        "configuration": {
          "type": "object",
          "additionalProperties": {
            "type": [
              "string",
              "number",
              "boolean"
            ]
          },
          "description": "Flat object of categorical settings. No nested objects allowed."
        }
      }
    },
    "context": {
      "type": "object",
      "required": [
        "environment",
        "temperature_K"
      ],
      "properties": {
        "environment": {
          "type": "string",
          "enum": ["operando", "in_situ", "ex_situ", "in_silico"]
        },
        "temperature_K": {
          "type": "number"
        },
        "electrochemistry": {
          "type": "object",
          "properties": {
            "reaction": {
              "type": "string",
              "enum": ["CO2RR", "CORR", "OER", "HER", "ORR", "NRR", "N2RR", "AOR", "FOR", "water_splitting", "surface_oxidation", "stripping_voltammetry", "None"]
            },
            "cell_type": {
              "type": "string",
              "enum": ["flow_cell", "microfluidic_flow_cell", "h_cell", "beaker_cell", "gde_cell", "mea_cell", "zero_gap_cell", "coin_cell", "three_electrode"]
            },
            "control_mode": {
              "type": "string",
              "enum": ["potentiostatic", "galvanostatic", "potentiodynamic", "open_circuit", "mixed"]
            },
            "potential_setpoint_V": { "type": "number" },
            "current_setpoint_mA_cm2": { "type": "number" },
            "potential_scale": {
              "type": "string",
              "enum": ["RHE", "SHE", "Ag/AgCl", "SCE", "Hg/HgO", "Hg/HgSO4", "V_vs_Ref"]
            },
            "scan_rate_mV_s": { "type": "number" },
            "ir_compensation": {
              "type": "object",
              "properties": {
                "method": {
                  "type": "string",
                  "enum": ["none", "automatic", "manual", "post_hoc", "EIS_based"]
                },
                "percent": { "type": "number" }
              }
            },
            "electrolyte": {
              "type": "object",
              "required": ["name", "concentration_M"],
              "properties": {
                "name": { "type": "string" },
                "concentration_M": { "type": "number" }
              }
            },
            "pH": { "type": "number" },
            "pH_basis": {
              "type": "string",
              "enum": ["measured", "nominal", "buffered_assumed"]
            }
          }
        },
        "transport": {
          "type": "object",
          "properties": {
            "flow_mode": {
              "type": "string",
              "enum": ["stagnant", "flowing_liquid", "bubbling_gas", "gas_diffusion", "rotating_disk"]
            },
            "rotation_speed_rpm": { "type": "number" },
            "feed": {
              "type": "object",
              "required": ["phase", "composition"],
              "properties": {
                "phase": {
                  "type": "string",
                  "enum": ["gas", "liquid"]
                },
                "composition": { "type": "string" },
                "flow_rate": { "type": "number" },
                "flow_rate_unit": { "type": "string" },
                "partial_pressures": { "type": "object" }
              },
              "description": "Feed must be an object with phase and composition. Do not use a bare string."
            }
          }
        },
        "thermodynamics": {
          "type": "object",
          "properties": {
            "pressure_Pa": { "type": "number" },
            "atmosphere": { "type": "string" }
          }
        },
        "simulation_assumptions": {
          "type": "object",
          "properties": {
            "solvation_model": {
              "type": "string",
              "enum": ["none", "implicit", "explicit"]
            }
          }
        }
      },
      "additionalProperties": false
    },
    "measurement": {
      "type": "object",
      "required": [
        "series",
        "qc"
      ],
      "properties": {
        "processing": {
          "type": "object"
        },
        "series": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "series_id",
              "independent_variables",
              "channels"
            ],
            "properties": {
              "series_id": {
                "type": "string"
              },
              "independent_variables": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "name",
                    "unit"
                  ],
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "unit": {
                      "type": "string"
                    },
                    "values": {
                      "type": "array",
                      "items": {
                        "type": "number"
                      }
                    }
                  }
                }
              },
              "channels": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "name",
                    "unit",
                    "role"
                  ],
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "unit": {
                      "type": "string"
                    },
                    "role": {
                      "type": "string",
                      "enum": [
                        "primary_signal",
                        "measured_response",
                        "simulated_observable",
                        "derived_signal",
                        "auxiliary_signal",
                        "control_readback",
                        "quality_monitor"
                      ]
                    },
                    "values": {
                      "type": "array",
                      "items": {
                        "type": "number"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "qc": {
          "type": "object",
          "required": [
            "status"
          ]
        }
      }
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "rel",
          "target",
          "basis"
        ],
        "properties": {
          "rel": {
            "type": "string",
            "enum": [
              "derived_from",
              "intended_comparison_target",
              "calibration_of",
              "same_sample_as",
              "replica_of",
              "follows",
              "validates",
              "invalidates"
            ]
          },
          "target": {
            "type": "string",
            "pattern": "^[0-9A-Z]{26}$"
          },
          "basis": {
            "type": "string",
            "enum": [
              "same_absorber_edge",
              "matched_operating_conditions",
              "matched_computational_method",
              "shared_reference_state",
              "same_workflow_version",
              "identical_geometry",
              "analysis_pipeline_output",
              "replicate_preparation",
              "same_sample_id",
              "shared_analysis_method",
              "shared_material_batch",
              "unspecified"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "asset_id",
          "content_role",
          "uri",
          "sha256"
        ],
        "properties": {
          "asset_id": {
            "type": "string"
          },
          "content_role": {
            "type": "string",
            "enum": [
              "raw_data",
              "raw_data_pointer",
              "reduction_product",
              "input_structure",
              "workflow_recipe",
              "processing_script",
              "calibration_reference",
              "auxiliary_reference",
              "documentation",
              "metadata_snapshot",
              "supplementary_image",
              "other"
            ]
          },
          "uri": {
            "type": "string"
          },
          "sha256": {
            "type": "string"
          },
          "media_type": {
            "type": "string"
          }
        }
      }
    },
    "descriptors": {
      "type": "object",
      "required": [
        "outputs"
      ],
      "properties": {
        "outputs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "label",
              "generated_utc",
              "generated_by",
              "descriptors"
            ],
            "properties": {
              "label": {
                "type": "string"
              },
              "generated_utc": {
                "type": "string",
                "format": "date-time",
                "description": "ISO 8601 timestamp of when the descriptors were generated. Placeholder strings are not allowed."
              },
              "generated_by": {
                "type": "object"
              },
              "descriptors": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "name",
                    "kind",
                    "source",
                    "value",
                    "uncertainty"
                  ],
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "kind": {
                      "type": "string",
                      "enum": [
                        "absolute",
                        "differential",
                        "categorical",
                        "similarity",
                        "model",
                        "theoretical_metric"
                      ]
                    },
                    "source": {
                      "type": "string",
                      "enum": [
                        "auto",
                        "manual",
                        "imported"
                      ]
                    },
                    "value": {
                      "not": { "type": "null" },
                      "description": "The asserted value. Must not be null — a descriptor without a value is not a scientific claim."
                    },
                    "unit": {
                      "type": "string"
                    },
                    "uncertainty": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "computation": {
      "type": "object",
      "properties": {
        "method": {
          "type": "object",
          "description": "Declared theory level: method family, functional, code details.",
          "properties": {
            "family": {
              "type": "string",
              "enum": ["DFT", "DFT_U", "hybrid_DFT", "AIMD", "classical_MD", "CHE", "microkinetic", "machine_learning", "semi_empirical"],
              "description": "Method family."
            },
            "functional_class": {
              "type": "string",
              "enum": ["LDA", "GGA", "meta_GGA", "hybrid", "double_hybrid", "RPA"],
              "description": "Density functional class."
            },
            "functional_name": {
              "type": "string",
              "description": "Specific functional (e.g., PBE, RPBE, BEEF-vdW, HSE06)."
            },
            "basis_type": {
              "type": "string",
              "enum": ["planewave", "LCAO", "real_space", "mixed"],
              "description": "Basis set type."
            },
            "pseudopotential": {
              "type": "string",
              "description": "Pseudopotential type (e.g., PAW, ultrasoft, norm_conserving, GBRV, SG15)."
            },
            "cutoff_eV": {
              "type": "number",
              "description": "Planewave kinetic energy cutoff in eV."
            },
            "spin_treatment": {
              "type": "string",
              "enum": ["none", "collinear", "noncollinear", "SOC"],
              "description": "Spin polarization treatment."
            },
            "dispersion": {
              "type": "string",
              "enum": ["none", "D2", "D3", "D3BJ", "TS", "MBD", "dDsC", "vdW_DF", "vdW_DF2", "rVV10"],
              "description": "Dispersion correction method."
            },
            "relativistic": {
              "type": "string",
              "enum": ["none", "scalar", "full"],
              "description": "Relativistic treatment."
            },
            "convergence": {
              "type": "object",
              "properties": {
                "energy_eV": { "type": "number" },
                "force_eV_per_A": { "type": "number" },
                "stress_kbar": { "type": "number" }
              }
            },
            "kpoints": {
              "type": "string",
              "description": "Brillouin zone sampling (e.g., '3x3x1 Monkhorst-Pack', 'Gamma-only')."
            },
            "smearing": {
              "type": "object",
              "properties": {
                "method": {
                  "type": "string",
                  "enum": ["Gaussian", "Methfessel-Paxton", "Fermi-Dirac", "tetrahedron", "cold"],
                  "description": "Electronic smearing method."
                },
                "width_eV": { "type": "number" }
              }
            }
          }
        },
        "slab_model": {
          "type": "object",
          "description": "Surface slab model parameters. Only relevant when sample.sample_form = 'slab_model'.",
          "properties": {
            "surface_facet": { "type": "string", "description": "e.g., '111', '100', '110', '211'" },
            "supercell": { "type": "string", "description": "e.g., '4x4', '4x3', '3x3'" },
            "layers": { "type": "integer" },
            "fixed_layers": { "type": "string", "description": "e.g., 'bottom 2'" },
            "vacuum_A": { "type": "number" },
            "lattice_constant_A": { "type": "number" },
            "dipole_correction": { "type": "boolean" }
          }
        },
        "potential_method": {
          "type": "object",
          "description": "How the electrochemical potential is treated in the simulation.",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["vacuum", "CHE", "implicit_solvent_PZC", "fixed_NELECT", "grand_canonical", "constant_potential", "joint_DFT"],
              "description": "Electrochemical potential treatment."
            },
            "target_potential_V_SHE": { "type": "number" },
            "SHE_work_function_eV": { "type": "number", "description": "Assumed SHE work function (typically 4.4-4.8 eV)." },
            "solvent_model": { "type": "string", "description": "Implicit solvent implementation (e.g., VASPsol, GLSSA13, CANDLE)." },
            "dielectric_constant": { "type": "number" }
          }
        },
        "output_quantity": {
          "type": "object",
          "description": "Specifies what quantity is computed and which corrections are applied. CRITICAL for valid comparison between records.",
          "properties": {
            "quantity": {
              "type": "string",
              "enum": ["E_DFT", "E_DFT_plus_ZPE", "delta_E", "delta_G_CHE", "delta_G_grand_canonical", "activation_energy_raw", "activation_energy_ZPE", "activation_free_energy"],
              "description": "The thermodynamic quantity reported in descriptors."
            },
            "corrections_applied": {
              "type": "object",
              "description": "Boolean flags for each correction included in the reported quantity.",
              "properties": {
                "zero_point_energy": { "type": "boolean" },
                "entropy": { "type": "boolean" },
                "thermal": { "type": "boolean" },
                "solvation": { "type": "boolean" },
                "dispersion": { "type": "boolean" },
                "grand_canonical": { "type": "boolean" },
                "PCET": { "type": "boolean" }
              }
            }
          }
        },
        "transition_state": {
          "type": "object",
          "description": "Transition state search parameters. Only for barrier calculations.",
          "properties": {
            "method": {
              "type": "string",
              "enum": ["NEB", "CI-NEB", "dimer", "string", "IRC", "growing_string"],
              "description": "TS search method."
            },
            "images": { "type": "integer", "description": "Number of NEB images." },
            "reaction": { "type": "string", "description": "e.g., 'CO* + CO* → OCCO*'" },
            "n_electrons_transferred": { "type": "integer", "description": "Electrons transferred in this step (0 for chemical, 1 for PCET)." }
          }
        }
      }
    }
  }
}